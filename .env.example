# =============================================================================
# Observatorio Tecnológico Industrial — Variables de Entorno
# =============================================================================
# Copiar este archivo como .env y ajustar según entorno:
#   cp .env.example .env
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=observatorio
POSTGRES_PASSWORD=observatorio_dev
POSTGRES_DB=observatorio_db

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=observatorio_dev
NEO4J_PLUGINS=["apoc","graph-data-science"]

# ── Redis ────────────────────────────────────────────────────────────────────
# Dejar vacío para deshabilitar autenticación (recomendado en desarrollo)
REDIS_PASSWORD=

# ── Backend ──────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-no-usar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Superusuario inicial ─────────────────────────────────────────────────────
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=admin
